# Frontend (Vite-Bundle, im Browser sichtbar) — gehört in .env
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-side secrets — gehören in .env.local (gitignored)
# SUPABASE_ACCESS_TOKEN: Personal Access Token aus supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DATABASE_URL: aus Supabase Dashboard → Project Settings → Database → Connection string → URI, mode "Session"
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ============================================================
# Akquise-Pipeline (Schritt 7) — nur in Vercel-Env, nicht lokal nötig
# ============================================================

# Microsoft Graph Webhook-Validation (eingehender Webhook von Graph muss diesen ClientState mitschicken)
# Generiere mit: openssl rand -hex 32  (oder PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 64 | % {[char]$_}))
MS_GRAPH_WEBHOOK_CLIENT_STATE=

# Microsoft Graph App-Auth (Azure-AD-App-Registration)
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=  # Verzeichnis-ID aus entra.microsoft.com → Übersicht (NICHT 'common' — wir sind Single-Tenant)
MS_GRAPH_MAILBOX_EMAIL=appv@appv7878.onmicrosoft.com  # M365-Postfach mit CRM-Eingang-Ordner

# OneDrive-Pfad-Konfiguration
ONEDRIVE_BASE_PATH=/Immobilien/001_AQUISE/Objekte
ONEDRIVE_LOCAL_PATH_PREFIX=C:\Users\andre\OneDrive - APPV Personalvermittlung\Immobilien\001_AQUISE\Objekte

# Supabase Service-Role-Key (für mail_queue-Schreibzugriff, bypasst RLS)
# ACHTUNG: NIEMALS im Frontend exposen — nur in Vercel-Env-Group "server-only"
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic-API für Address-Extraktion + QuickCheck-Stub
ANTHROPIC_API_KEY=
