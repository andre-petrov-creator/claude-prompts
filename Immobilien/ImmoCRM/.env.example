# Frontend (Vite-Bundle, im Browser sichtbar) — gehört in .env
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-side secrets — gehören in .env.local (gitignored)
# SUPABASE_ACCESS_TOKEN: Personal Access Token aus supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DATABASE_URL: aus Supabase Dashboard → Project Settings → Database → Connection string → URI, mode "Session"
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
